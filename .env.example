# ── Copy this file to .env and fill in your values ───────────────
# cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=exam_builder

# ── Backend database URLs ─────────────────────────────────────────
# Async URL (used by FastAPI / SQLAlchemy asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/exam_builder
# Sync URL (used by Alembic)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5433/exam_builder

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Frontend ──────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── LLM provider (mock | openai | ollama) ────────────────────────
LLM_PROVIDER=mock
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
